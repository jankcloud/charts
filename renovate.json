{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:helmChartYamlAppVersions",
    "helpers:pinGitHubActionDigests",
  ],
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "{{currentVersion}} → {{newVersion}}",
  "gitIgnoredAuthors": ["jankbot@users.noreply.github.com"],
  "prHourlyLimit": 0,
  "additionalBranchPrefix": "{{parentDir}}-",
  "bumpVersions": [
    {
      "filePatterns": ["{{packageFileDir}}/Chart.{yaml,yml}"],
      "matchStrings": ["version:\\s(?<version>[^\\s]+)"],
      "bumpType": "{{#if isPatch}}patch{{else}}minor{{/if}}"
    }
  ],
  "helmv3" : {
    "managerFilePatterns": ["/(^|/)Chart\\.ya?ml$/"],
    "postUpdateOptions": ["helmUpdateSubChartArchives"]
  },
  "helm-values" : {
    "managerFilePatterns": [
      "/(^|/)values\\.ya?ml$/"
    ],
    "pinDigests": true
  },
  "pre-commit": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Disable digest pinning for latest docker images in helm-values",
      "matchDatasources": ["docker"],
      "matchCurrentValue": "/^latest$/",
      "matchFileNames": ["**/values.yaml", "**/values.yml"],
      "pinDigests": false
    },
    {
      "matchManagers": ["helmv3"],
      "semanticCommitScope": "{{parentDir}}"
    },
    {
      "matchManagers": ["helm-values"],
      "semanticCommitScope": "{{parentDir}}"
    },
  ]
}
