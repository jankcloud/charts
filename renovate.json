{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "gitIgnoredAuthors": ["jankbot@users.noreply.github.com"],
  "prHourlyLimit": 0,
  "helmv3" : {
    "managerFilePatterns": ["/(^|/)Chart\\.ya?ml$/"],
    "postUpdateOptions": ["helmUpdateSubChartArchives"]
  },
  "helm-values" : {
    "managerFilePatterns": [
      "/(^|/)values\\.ya?ml$/"
    ],
    "pinDigests": true
  }
}
